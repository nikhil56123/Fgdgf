rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint for Projects
    function isValidProject(data) {
      return data.keys().hasAll(['ownerId', 'name', 'modType', 'id'])
        && data.ownerId == request.auth.uid
        && data.id is string
        && data.name is string && data.name.size() <= 100
        && data.modType in ['forge', 'fabric', 'neoforge', 'quilt'];
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isVerified() 
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    match /projects/{projectId} {
      // Secure List Queries: The rule itself must validate the resource being queried
      allow list: if isVerified() && resource.data.ownerId == request.auth.uid;
      allow get: if isVerified() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isVerified() 
        && isValidId(projectId)
        && isValidProject(request.resource.data);
        
      allow update: if isOwner(resource.data.ownerId)
        && isValidProject(request.resource.data)
        && request.resource.data.ownerId == resource.data.ownerId;
        
      allow delete: if isOwner(resource.data.ownerId);
    }

    match /community_mods/{modId} {
      allow read: if true;
      allow create: if isVerified() 
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.keys().hasAll(['authorId', 'projectId', 'name', 'modType'])
        && request.resource.data.likesCount == 0
        && request.resource.data.commentsCount == 0;
      allow update: if isVerified()
        && (
          // Author can update metadata
          (resource.data.authorId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'description', 'version', 'mcVersion'])) ||
          // Anyone can increment/decrement likes/comments (simplified for demo, ideally use increment() in rules)
          (request.resource.data.diff(resource.data).affectedKeys().hasAny(['likesCount', 'commentsCount']))
        );
      allow delete: if isVerified() && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isVerified() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isVerified() && resource.data.authorId == request.auth.uid;
      }
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if isVerified() && followId.startsWith(request.auth.uid + "_");
    }
  }
}
